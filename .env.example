# Required: Anthropic API key for Claude chat and tree search
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key (only if you want to use OpenAI for PageIndex indexing)
OPENAI_API_KEY=sk-...

# Model for PageIndex tree generation/summaries (litellm format)
# Use "anthropic/claude-sonnet-4-20250514" for Claude or "gpt-4o-2024-11-20" for OpenAI
PAGEINDEX_MODEL=anthropic/claude-sonnet-4-20250514

# Model for chat responses (anthropic SDK format, no prefix)
CHAT_MODEL=claude-sonnet-4-20250514
